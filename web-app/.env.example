# Base URL of the OpenTune web API. Leave blank to use the same origin the app is served from.
VITE_API_BASE=

# Optional. Store listing URL for the OpenTune Login Helper extension.
#
# The helper is NOT published, so this is intentionally blank: a placeholder URL would render an
# install button that goes nowhere. Pairing with the Android app is the recommended way to sign in,
# and needs no extension at all. Leave this unset unless you have actually published the helper.
VITE_OPENTUNE_HELPER_INSTALL_URL=
