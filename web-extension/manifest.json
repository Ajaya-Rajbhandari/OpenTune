{
  "manifest_version": 3,
  "name": "OpenTune Login Helper",
  "short_name": "OpenTune Helper",
  "version": "0.1.0",
  "description": "Connects a YouTube Music browser login to the local OpenTune web app.",
  "homepage_url": "https://github.com/Ajaya-Rajbhandari/OpenTune",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "OpenTune Login Helper",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["cookies", "scripting", "tabs"],
  "optional_host_permissions": ["http://*/*"],
  "host_permissions": [
    "https://accounts.google.com/*",
    "https://music.youtube.com/*",
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:8080/*",
        "http://127.0.0.1:8080/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*"
      ],
      "js": ["opentune-page.js"],
      "run_at": "document_start"
    }
  ]
}
